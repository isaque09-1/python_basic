#list comprehension é uma forma concisa de criar listas a partir de iteráveis,
#  aplicando uma expressão a cada elemento e opcionalmente filtrando os elementos com uma condição.
#  Ela é mais eficiente e legível do que usar loops tradicionais para criar listas.


#for sem lista , ele é usado para executar um bloco de código repetidamente,
#  iterando sobre uma sequência de elementos ou executando um número específico de vezes.
for i in range(5):
    print(f'Número: {i}')
for i in range (1,6):# o range começa em 1 e vai até 5, ou seja, ele gera os números de 1 a 5-
    print(f'Número: {i}')
for i in range (0,10,2):# o range começa em 0, vai até 10 (exclusivo) e incrementa de 2 em 2, ou seja, ele gera os números pares de 0 a 8
    print(f'Número: {i}')

for i in range(10,0,-2):# o range começa em 10, vai até 0 (exclusivo) e decrementa de 1 em 1, ou seja, ele gera os números de 10 a 1 em ordem decrescente
